<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="#00000000">

    <!-- The Icon now uses weight.
         If expanded_ui is GONE, this takes 100% of the space perfectly (1x1).
         If expanded_ui is VISIBLE, it dynamically shrinks. -->
    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:contentDescription="@string/toggle_bluetooth" />

    <!-- The Expanded UI Panel -->
    <LinearLayout
        android:id="@+id/expanded_ui"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3.5"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text= "@string/bluetooth_is_on"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_device_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ready_to_connect"
            android:textColor="#A1A1AA"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"/>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/widget_btn_chat"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/chat"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3B82F6"
                android:padding="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/widget_btn_scan"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/app"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#27272A"
                android:padding="0dp"
                android:layout_marginStart="4dp"/>

            <Button
                android:id="@+id/widget_btn_settings"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/config"
                android:textSize="11sp"
                android:textColor="#A1A1AA"
                android:backgroundTint="#18181B"
                android:padding="0dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>